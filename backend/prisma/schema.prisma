generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(120)
  slug         String   @unique @db.VarChar(140)
  description  String?
  imageUrl     String?  @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  dolls        Doll[]

  @@index([slug], map: "idx_categories_slug")
  @@index([isActive], map: "idx_categories_active")
  @@index([displayOrder], map: "idx_categories_display_order")
  @@map("categories")
}

model Collection {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(120)
  slug         String   @unique @db.VarChar(140)
  description  String?
  imageUrl     String?  @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  dolls        Doll[]

  @@index([slug], map: "idx_collections_slug")
  @@index([isActive], map: "idx_collections_active")
  @@index([displayOrder], map: "idx_collections_display_order")
  @@map("collections")
}

model Doll {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String?     @unique @db.VarChar(40)
  name          String      @db.VarChar(160)
  slug          String      @unique @db.VarChar(180)
  description   String
  price         Decimal     @db.Decimal(12, 2)
  imageUrl      String      @map("image_url")
  tag           String?     @db.VarChar(80)
  productType   String      @default("doll") @map("product_type") @db.VarChar(30)
  available     Boolean     @default(true)
  stockQuantity Int         @default(0) @map("stock_quantity")
  popularity    Int         @default(0)
  isFeatured    Boolean     @default(false) @map("is_featured")
  categoryId    String      @map("category_id") @db.Uuid
  collectionId  String      @map("collection_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  collection    Collection  @relation(fields: [collectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  comboItems    ComboItem[]

  @@index([code], map: "idx_dolls_code")
  @@index([slug], map: "idx_dolls_slug")
  @@index([categoryId], map: "idx_dolls_category_id")
  @@index([collectionId], map: "idx_dolls_collection_id")
  @@index([productType], map: "idx_dolls_product_type")
  @@index([available], map: "idx_dolls_available")
  @@index([isFeatured], map: "idx_dolls_is_featured")
  @@index([price], map: "idx_dolls_price")
  @@index([popularity], map: "idx_dolls_popularity")
  @@index([createdAt], map: "idx_dolls_created_at")
  @@map("dolls")
}

model Combo {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String?     @unique @db.VarChar(40)
  name          String      @db.VarChar(160)
  slug          String      @unique @db.VarChar(180)
  description   String
  price         Decimal     @db.Decimal(12, 2)
  imageUrl      String      @map("image_url")
  tag           String?     @db.VarChar(80)
  available     Boolean     @default(true)
  stockQuantity Int         @default(0) @map("stock_quantity")
  popularity    Int         @default(0)
  isFeatured    Boolean     @default(false) @map("is_featured")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items         ComboItem[]

  @@index([code], map: "idx_combos_code")
  @@index([slug], map: "idx_combos_slug")
  @@index([available], map: "idx_combos_available")
  @@index([isFeatured], map: "idx_combos_is_featured")
  @@index([price], map: "idx_combos_price")
  @@index([popularity], map: "idx_combos_popularity")
  @@index([createdAt], map: "idx_combos_created_at")
  @@map("combos")
}

model ComboItem {
  comboId   String   @map("combo_id") @db.Uuid
  dollId    String   @map("product_id") @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  combo     Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  doll      Doll     @relation(fields: [dollId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([comboId, dollId])
  @@index([comboId], map: "idx_combo_items_combo_id")
  @@index([dollId], map: "idx_combo_items_product_id")
  @@map("combo_items")
}

model NewsletterSubscriber {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.Citext
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email], map: "idx_newsletter_email")
  @@index([isActive], map: "idx_newsletter_active")
  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  email     String   @db.Citext
  subject   String   @db.VarChar(180)
  message   String
  status    String   @default("pending") @db.VarChar(40)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email], map: "idx_contact_messages_email")
  @@index([status], map: "idx_contact_messages_status")
  @@index([createdAt], map: "idx_contact_messages_created_at")
  @@map("contact_messages")
}
